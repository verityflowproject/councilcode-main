# Database
MONGODB_URI=
REDIS_URL=

# Auth
NEXTAUTH_SECRET=
NEXTAUTH_URL=http://localhost:3000

# AI Model API Keys
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
MISTRAL_API_KEY=
GOOGLE_AI_API_KEY=
PERPLEXITY_API_KEY=

# Encryption key for BYOK user API key storage (AES-256-GCM)
# Generate with: openssl rand -hex 32
ENCRYPTION_KEY=

# Platform API keys (server-side only — used when users have no BYOK keys)
# These are YOUR provider accounts. Users never see these.
PLATFORM_ANTHROPIC_KEY=
PLATFORM_OPENAI_KEY=
PLATFORM_MISTRAL_KEY=
PLATFORM_GOOGLE_AI_KEY=
PLATFORM_PERPLEXITY_KEY=

# Stripe
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# Stripe plan price IDs (create in Stripe dashboard)
STRIPE_PRO_PRICE_ID=
STRIPE_TEAMS_PRICE_ID=

# Stripe credit pack price IDs (one-time payments, not subscriptions)
STRIPE_CREDITS_STARTER_PRICE_ID=
STRIPE_CREDITS_BUILDER_PRICE_ID=
STRIPE_CREDITS_PRO_PACK_PRICE_ID=
STRIPE_CREDITS_STUDIO_PRICE_ID=
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Email provider (e.g. Resend, SendGrid SMTP)
EMAIL_SERVER=
EMAIL_FROM=

# Cron secret for usage reset endpoint
CRON_SECRET=
